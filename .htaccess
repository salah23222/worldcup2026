# ============================================================
# World Cup 2026 — .htaccess
# أمان + ضغط + كاش للملفات الثابتة
# ============================================================

# ---------- منع عرض محتويات المجلدات ----------
Options -Indexes

# ---------- حماية الملفات الحساسة ----------
<FilesMatch "\.(json|md|log)$">
  Require all denied
</FilesMatch>

# منع الوصول للملفات المخفية (.htaccess, .gitignore, .env ...)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# منع الوصول المباشر لملفات الإعداد (دفاع في العمق إن تعطّل تنفيذ PHP)
<FilesMatch "^config(\.local)?(\.example)?\.php$">
  Require all denied
</FilesMatch>

# ---------- ضغط GZIP ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain
  AddOutputFilterByType DEFLATE application/javascript application/json
</IfModule>

# ---------- كاش المتصفح للملفات الثابتة ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css            "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png           "access plus 30 days"
  ExpiresByType image/jpeg          "access plus 30 days"
  ExpiresByType image/svg+xml       "access plus 30 days"
</IfModule>

# ---------- ترويسات أمان ----------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(self), microphone=(), camera=(), payment=()"
  # سياسة أمان المحتوى (CSP) — دفاع في العمق ضد XSS وحقن الموارد.
  # img-src https: مسموح لأن صور الأخبار تأتي من مصادر RSS متعددة؛ الخطوط من Google Fonts.
  # ملاحظة: 'unsafe-inline' للسكربتات/الأنماط مؤقّت (الموقع يستخدم inline) — يُشدَّد لاحقاً عبر nonce.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
  # الودجت قابل للتضمين في أي موقع — اسمح بالتأطير له فقط مع بقاء بقية الحماية.
  <FilesMatch "^widget\.php$">
    Header unset X-Frame-Options
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors *"
  </FilesMatch>
</IfModule>

# ---------- روابط لطيفة لخريطة الموقع ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

# ---------- صفحة الخطأ ----------
ErrorDocument 404 /index.php

# ---------- الترميز الافتراضي ----------
AddDefaultCharset UTF-8
